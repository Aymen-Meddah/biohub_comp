import torch.nn as nn 
from monai.losses import DiceLoss, DiceCELoss


def get_loss (name="divece"):
    name = name.lower()
    if name == "dice":
        return DiceLoss(sigmoid=True ,squre_pred=True)
    elif name == "dicece":
        return DiceCELoss(sigmoid=True ,squre_pred=True)
    elif name == "bce":
        return nn.BCEWithLogitsLoss()
    else:
        raise ValueError(f"Unknown loss function: {name}")
    